# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Solapi (SMS)
SOLAPI_API_KEY=your-api-key
SOLAPI_API_SECRET=your-api-secret
SOLAPI_SENDER_NUMBER=01012345678

# Kakao OAuth
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=https://yourdomain.com/api/auth/kakao/callback

# Make.com
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/your-webhook

# App
NEXT_PUBLIC_APP_URL=https://bbk-app.vercel.app

# Gmail SMTP (이메일 발송 — 앱 비밀번호 방식)
# 설정 방법: Google 계정 → 보안 → 2단계 인증 활성화 → 앱 비밀번호 생성
GMAIL_USER=sunrise@bbkorea.co.kr
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# 계약서 완료 이메일 수신 관리자 주소
ADMIN_EMAIL=sunrise@bbkorea.co.kr
