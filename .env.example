# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Solapi (SMS)
SOLAPI_API_KEY=your-api-key
SOLAPI_API_SECRET=your-api-secret
SOLAPI_SENDER_NUMBER=01012345678

# Kakao OAuth
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=https://yourdomain.com/api/auth/kakao/callback

# Make.com
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/your-webhook

# App
NEXT_PUBLIC_APP_URL=https://bbk-app.vercel.app

# Webhook
# Make.com → /api/webhooks/* 호출 시 인증에 사용되는 시크릿
WEBHOOK_SECRET=your-webhook-secret

# Google Drive (급여정산 엑셀 자동 업로드 — 서비스 계정 방식)
# 설정 방법: Google Cloud Console → IAM → 서비스 계정 생성 → JSON 키 발급
#            → Drive 대상 폴더를 서비스 계정 이메일로 공유 (편집자 권한)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Google Drive 자동 저장 (견적서 PDF — OAuth2 Refresh Token 방식)
# 발급 방법:
#   1. https://developers.google.com/oauthplayground 접속
#   2. 우측 상단 톱니바퀴 → "Use your own OAuth credentials" 체크
#   3. Client ID: NEXT_PUBLIC_GOOGLE_CLIENT_ID 값 입력
#      Client Secret: GOOGLE_CLIENT_SECRET 값 입력
#   4. 왼쪽 검색창에 "Drive API v3" → https://www.googleapis.com/auth/drive 선택 → Authorize APIs
#   5. BBK Google 계정으로 로그인 후 권한 허용
#   6. "Exchange authorization code for tokens" 클릭
#   7. 표시된 refresh_token 값을 아래에 입력
GOOGLE_DRIVE_REFRESH_TOKEN=your-refresh-token-here

# Web Push (VAPID)
# 생성: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your@email.com

# Gmail SMTP (이메일 발송 — 앱 비밀번호 방식)
# 설정 방법: Google 계정 → 보안 → 2단계 인증 활성화 → 앱 비밀번호 생성
GMAIL_USER=sunrise@bbkorea.co.kr
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# 계약서 완료 이메일 수신 관리자 주소
ADMIN_EMAIL=sunrise@bbkorea.co.kr

# 국세청 사업자등록 상태조회 API (공공데이터포털)
# 발급: https://www.data.go.kr → "국세청_사업자등록정보 진위확인 및 상태조회 서비스" 검색 → 활용신청
# /bbk-care 신청서 페이지의 사업자등록번호 확인 기능에 사용됨
NTS_SERVICE_KEY=your-nts-service-key
